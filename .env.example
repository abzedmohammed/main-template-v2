# ─── App config (bundled into the client at build time) ──────────────────
VITE_API_URL=http://localhost:8080
VITE_LOGOUT_URL=/
VITE_DEFAULT_TIMER=10
VITE_FIGMA_TOKEN=FIGMA_TOKEN_HERE

# Session timing (optional — sensible defaults applied in src/utils.jsx)
VITE_SESSION_IDLE_TIMEOUT_MINUTES=15
VITE_SESSION_MAX_DURATION_MINUTES=60
VITE_SESSION_ABSOLUTE_MAX_MINUTES=240
VITE_SESSION_WARNING_COUNTDOWN_SECONDS=60
VITE_SESSION_EXPIRY_COUNTDOWN_SECONDS=30

# ─── Deploy / CI config (consumed by .gitlab-ci.yml; NEVER bundled) ───────
# Everything in the VITE_CI_ namespace is excluded from the client bundle by a
# single rule in the build (`grep -v '^VITE_CI_'`). Push to GitLab CI/CD with
# env-upload.sh. Single source of truth for the pipeline.
VITE_CI_APP_NAME=app-frontend
VITE_CI_DEPLOY_NETWORK=app-net
VITE_CI_FRONTEND_PORT=3010
VITE_CI_TEST_URL=https://test.example.com/
VITE_CI_PROD_URL=https://example.com/
VITE_CI_SONAR_PROJECT_KEY=app-frontend
VITE_CI_SONAR_PROJECT_NAME=App Frontend
VITE_CI_VPN_PING_HOST=10.10.40.4

# ─── Tooling only (keep real values in .env.local; never pushed, never bundled) ──
# Used by env-upload.sh to target the right GitLab project.
VITE_CI_GITLAB_PROJECT_ID=
# VITE_CI_GITLAB_TOKEN=   # personal access token (api scope) for env-upload.sh
